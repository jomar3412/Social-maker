# === AI Model API Keys (Multi-Model Pipeline) ===
# Claude - Final assembly, structure enforcement
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ChatGPT - Initial script drafting
OPENAI_API_KEY=your-openai-api-key-here

# Gemini - Trend research, relevance checking
GOOGLE_API_KEY=your-google-api-key-here

# Grok - Viral angles from X, hook sharpening
XAI_API_KEY=your-xai-api-key-here

# ElevenLabs - Voice generation
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# === ElevenLabs Settings ===
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# === YouTube OAuth (set up via Google Cloud Console) ===
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# === Instagram / Meta ===
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# === TikTok ===
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# === Cloud Storage (Optional) ===
# Mount Google Drive with rclone, then set paths here
# Leave empty to use local ./assets and ./output folders
#
# Example for Google Drive mount:
#   ASSETS_DIR=/mnt/gdrive/socal_maker/assets
#   OUTPUT_DIR=/mnt/gdrive/socal_maker/output
#
ASSETS_DIR=
OUTPUT_DIR=

# === Google Cloud AI (Auto-Tagging) ===
# For AI-powered video/image auto-tagging
# 1. Create GCP project: https://console.cloud.google.com/
# 2. Enable "Cloud Video Intelligence API" and "Cloud Vision API"
# 3. Create service account with "Cloud Vision API User" role
# 4. Download JSON key and set path below
#
# Free tier: 1,000 minutes/month (enough for ~2,000 videos)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json
